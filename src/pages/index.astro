---
/**
 * Visor de Widgets — UI Kit / Storybook interno del Design System V2.
 * -------------------------------------------------------------------
 * Funcionalidades:
 *   1. Sidebar oscuro con índice de widgets + switcher de BU
 *      (pills con swatch real, leído desde `bu-colors.json`).
 *   2. Por cada widget:
 *      - Header con título + viewport switcher (Desktop / Tablet / Mobile)
 *      - Preview a FULL WIDTH (con `max-width` aplicado según viewport).
 *      - Drawer de "Props" a la derecha, oculto por defecto (toggle).
 *      - Live editing: cambiar inputs/textarea actualiza el preview.
 *   3. Persistencia del BU seleccionado en `localStorage`.
 *
 * Layout:
 *   sidebar (280px, slate-800)  │  main (slate-900)
 *                                │
 *                                │  ┌─ widget head ──────────────┐
 *                                │  │ Title           [D|T|M] ⚙ │
 *                                │  └────────────────────────────┘
 *                                │  ┌─ preview ──────┐ ┌─ drawer ┐
 *                                │  │  (full width)  │ │ (hidden)│
 *                                │  │                │ │         │
 *                                │  └────────────────┘ └─────────┘
 *
 * Estrategia de tema:
 *   - El switcher de BU setea `data-bu` en <html>.
 *   - Los tokens se resuelven vía CSS variables en `global.css`:
 *       [data-bu="pregrado"] { --bu-color-brand-primary: #...; }
 *   - Tailwind v4 @theme genera utilities `bg-bu-primary`, etc.
 *
 * Cómo registrar un widget nuevo:
 *   Ver `generador-landings/src/components/widgets/registry.ts` (registry central).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { widgetRegistry } from '../components/widgets/registry.ts';
import { ICON_PATHS } from '../components/widgets/5-save-the-date/icons.ts';
import buColors from '@data/bu-colors.json';

// Normalizamos el JSON a una lista [{id, primary, secondary, ...}].
const busList = Object.entries(buColors.bus).map(([id, palette]) => ({
  id,
  ...(palette as { primary: string; secondary: string; accent: string; surface: string; neutral: string }),
}));
---

<BaseLayout
  title="Visor de Widgets"
  description="Catálogo navegable del Design System V2 con switcher de unidad de negocio y viewport responsive."
>
  <style>
    /* ============================================================
       Visor — fondo oscuro para que solo el widget "salte" al ojo
       ============================================================ */
    .visor {
      display: grid;
      grid-template-columns: 280px 1fr;
      min-height: 100vh;
      background: #0f172a;            /* slate-900 — fondo principal oscuro */
      color: #e2e8f0;                 /* slate-200 — texto base */
      font-family: 'Montserrat', system-ui, sans-serif;
    }

    /* ── SIDEBAR ──────────────────────────────────────────────── */
    .visor__sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      background: #1e293b;            /* slate-800 */
      border-right: 1px solid #334155;
      padding: 1.5rem 1rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .visor__brand h1 {
      font-size: 1.125rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      margin: 0;
      color: #f1f5f9;
    }
    .visor__brand p {
      font-size: 0.6875rem;
      color: #64748b;
      margin: 0.25rem 0 0;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .visor__sidebar-label {
      display: block;
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #64748b;
      margin-bottom: 0.625rem;
    }
    .visor__bus-list {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }
    .visor__bu-pill {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.8125rem;
      font-weight: 600;
      border: 1px solid #334155;
      border-radius: 0.5rem;
      background: #0f172a;
      cursor: pointer;
      transition: all 0.15s ease;
      color: #cbd5e1;
      text-align: left;
      width: 100%;
    }
    .visor__bu-pill:hover {
      border-color: #475569;
      color: #f1f5f9;
    }
    .visor__bu-pill.is-active {
      border-color: var(--bu-color-brand-primary, #3b82f6);
      background: var(--bu-color-brand-primary, #3b82f6);
      color: #ffffff;
    }
    .visor__bu-swatch {
      width: 0.875rem;
      height: 0.875rem;
      border-radius: 999px;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.25);
      flex-shrink: 0;
    }
    .visor__nav ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
    }
    .visor__nav a {
      display: block;
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
      color: #cbd5e1;
      text-decoration: none;
      border-radius: 0.5rem;
      transition: all 0.15s ease;
      cursor: pointer;
    }
    .visor__nav a:hover {
      background: #334155;
      color: #f1f5f9;
    }
    .visor__nav a.is-active {
      background: var(--bu-color-brand-primary, #3b82f6);
      color: #ffffff;
    }

    /* ── MAIN ────────────────────────────────────────────────── */
    .visor__main {
      padding: 1.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      overflow-y: auto;
      height: 100vh;
      box-sizing: border-box;
    }

    /* ── WIDGET SECTION ──────────────────────────────────────── */
    .visor__widget-section {
      background: #1e293b;
      border: 1px solid #334155;
      border-radius: 1rem;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .visor__widget-section.is-hidden,
    .visor__widget-section[hidden] {
      display: none;
    }
    .visor__widget-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid #334155;
      background: rgba(15, 23, 42, 0.5);
      flex-wrap: wrap;
    }
    .visor__widget-title h2 {
      font-size: 1rem;
      font-weight: 800;
      margin: 0;
      color: #f1f5f9;
    }
    .visor__widget-title p {
      font-size: 0.8125rem;
      color: #94a3b8;
      margin: 0.25rem 0 0;
      max-width: 480px;
    }
    .visor__widget-toolbar {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    /* ── VIEWPORT SWITCHER ───────────────────────────────────── */
    .visor__viewport-switcher {
      display: inline-flex;
      background: #0f172a;
      border: 1px solid #334155;
      border-radius: 0.5rem;
      padding: 0.25rem;
      gap: 0.125rem;
    }
    .visor__viewport-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.4375rem 0.75rem;
      color: #94a3b8;
      border: none;
      border-radius: 0.375rem;
      background: transparent;
      cursor: pointer;
      transition: all 0.15s ease;
      font-size: 0.75rem;
      font-weight: 600;
      font-family: inherit;
    }
    .visor__viewport-btn:hover {
      color: #f1f5f9;
    }
    .visor__viewport-btn.is-active {
      background: #3b82f6;
      color: #ffffff;
    }
    .visor__viewport-btn svg {
      width: 0.875rem;
      height: 0.875rem;
    }

    /* ── EDIT TOGGLE ─────────────────────────────────────────── */
    .visor__edit-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.4375rem 0.875rem;
      background: #0f172a;
      color: #cbd5e1;
      border: 1px solid #334155;
      border-radius: 0.5rem;
      font-size: 0.75rem;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .visor__edit-toggle:hover {
      color: #f1f5f9;
      border-color: #475569;
    }
    .visor__edit-toggle.is-active {
      background: #3b82f6;
      color: #ffffff;
      border-color: #3b82f6;
    }

    /* ── WIDGET BODY (preview + drawer) ──────────────────────── */
    .visor__widget-body {
      display: grid;
      grid-template-columns: 1fr;
      transition: grid-template-columns 0.3s ease;
    }
    .visor__widget-body.has-controls {
      grid-template-columns: 1fr 340px;
    }

    /* ── PREVIEW ─────────────────────────────────────────────── */
    .visor__preview-wrap {
      padding: 1.5rem;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      min-height: 240px;
    }
    .visor__preview-frame {
      width: 100%;
      background: #ffffff;
      border-radius: 0.5rem;
      overflow: hidden;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
      transition: max-width 0.3s ease, width 0.3s ease;
    }
    /* Tamaños de viewport (como el switcher del visor V1) */
    .visor__preview-frame[data-viewport="desktop"] { max-width: 100%; }
    .visor__preview-frame[data-viewport="tablet"]  { max-width: 780px; }
    .visor__preview-frame[data-viewport="mobile"]  { max-width: 375px; }

    .visor__preview-instance {
      position: relative;
    }
    .visor__preview-instance[hidden] {
      display: none;
    }

    /* ── CONTROLS DRAWER ─────────────────────────────────────── */
    .visor__controls {
      background: #0f172a;
      border-left: 1px solid #334155;
      padding: 1.25rem;
      display: none;
      flex-direction: column;
      gap: 1rem;
      overflow-y: auto;
      max-height: 80vh;
    }
    .visor__widget-body.has-controls .visor__controls {
      display: flex;
    }
    .visor__control {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }
    .visor__control label {
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #64748b;
    }
    .visor__control input,
    .visor__control textarea,
    .visor__control select {
      width: 100%;
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
      font-family: inherit;
      border: 1px solid #334155;
      border-radius: 0.5rem;
      background: #1e293b;
      color: #e2e8f0;
      transition: all 0.15s ease;
      box-sizing: border-box;
    }
    .visor__control input:focus,
    .visor__control textarea:focus,
    .visor__control select:focus {
      outline: none;
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
    }
    .visor__control textarea {
      resize: vertical;
      min-height: 5rem;
      font-family: 'JetBrains Mono', 'Menlo', monospace;
      font-size: 0.8125rem;
    }
    .visor__controls-hint {
      font-size: 0.75rem;
      color: #64748b;
      line-height: 1.5;
      padding: 0.625rem 0.75rem;
      background: rgba(59, 130, 246, 0.08);
      border-left: 2px solid #3b82f6;
      border-radius: 0.25rem;
      margin: 0;
    }
    .visor__control-hint-inline {
      display: block;
      font-weight: 400;
      font-size: 0.625rem;
      color: #64748b;
      text-transform: none;
      letter-spacing: 0;
      margin-top: 0.125rem;
    }

    /* ── Cards editor ────────────────────────────────────────── */
    .visor__cards-list {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .visor__card-row {
      display: grid;
      grid-template-columns: auto 1fr 1fr auto;
      gap: 0.375rem;
      align-items: center;
    }
    .visor__card-row select,
    .visor__card-row input {
      padding: 0.4375rem 0.5rem;
      font-size: 0.8125rem;
      border: 1px solid #334155;
      border-radius: 0.375rem;
      background: #1e293b;
      color: #e2e8f0;
    }
    .visor__card-icon {
      min-width: 5.5rem;
    }
    .visor__card-remove {
      width: 1.75rem;
      height: 1.75rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid #334155;
      border-radius: 0.375rem;
      background: #1e293b;
      color: #f87171;
      cursor: pointer;
      font-size: 0.875rem;
      line-height: 1;
    }
    .visor__card-remove:hover {
      background: #7f1d1d;
      color: #ffffff;
      border-color: #7f1d1d;
    }
    .visor__card-add {
      margin-top: 0.5rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.75rem;
      font-weight: 600;
      border: 1px dashed #475569;
      border-radius: 0.5rem;
      background: transparent;
      color: #94a3b8;
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .visor__card-add:hover {
      border-color: #3b82f6;
      color: #3b82f6;
      background: rgba(59, 130, 246, 0.05);
    }

    /* ── Mode switcher (light/dark) ───────────────────────────── */
    .visor__mode-switcher {
      display: inline-flex;
      background: #0f172a;
      border: 1px solid #334155;
      border-radius: 0.5rem;
      padding: 0.25rem;
      gap: 0.125rem;
      width: 100%;
    }
    .visor__mode-btn {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.375rem;
      padding: 0.4375rem 0.75rem;
      color: #94a3b8;
      border: none;
      border-radius: 0.375rem;
      background: transparent;
      cursor: pointer;
      transition: all 0.15s ease;
      font-size: 0.75rem;
      font-weight: 600;
      font-family: inherit;
    }
    .visor__mode-btn:hover {
      color: #f1f5f9;
    }
    .visor__mode-btn.is-active {
      background: var(--bu-color-brand-primary, #3b82f6);
      color: var(--bu-color-neutral, #ffffff);
    }

    /* ── RESPONSIVE ──────────────────────────────────────────── */
    @media (max-width: 1024px) {
      .visor {
        grid-template-columns: 1fr;
      }
      .visor__sidebar {
        position: relative;
        height: auto;
      }
      .visor__widget-body.has-controls {
        grid-template-columns: 1fr;
      }
      .visor__widget-body.has-controls .visor__controls {
        border-left: none;
        border-top: 1px solid #334155;
      }
    }
  </style>

  <div class="visor">

    {/* ── SIDEBAR ─────────────────────────────────────────────── */}
    <aside class="visor__sidebar">
      <header class="visor__brand">
        <h1>Visor V2</h1>
        <p>Design System · UI Kit</p>
      </header>

      <section>
        <label class="visor__sidebar-label">Unidad de Negocio</label>
        <div class="visor__bus-list" role="radiogroup" aria-label="Cambiar unidad de negocio">
          {busList.map((bu, i) => (
            <button
              type="button"
              class="visor__bu-pill"
              data-bu-target={bu.id}
              role="radio"
              aria-checked={i === 0 ? 'true' : 'false'}
            >
              <span class="visor__bu-swatch" style={`background:${bu.primary}; ${bu.primary.startsWith('#______') ? 'background: linear-gradient(135deg, #cbd5e1 50%, #475569 50%);' : ''}`}></span>
              <span>{bu.id}</span>
            </button>
          ))}
        </div>
      </section>

      <nav class="visor__nav">
        <label class="visor__sidebar-label">Widgets</label>
        <ul>
          {widgetRegistry.map((w, i) => (
            <li>
              <a
                href={`#${w.id}`}
                data-widget-nav={w.id}
                class:list={[i === 0 && 'is-active']}
                aria-current={i === 0 ? 'true' : undefined}
              >{w.name}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    {/* ── MAIN ────────────────────────────────────────────────── */}
    <main class="visor__main">
      {widgetRegistry.map((w, i) => (
        <section
          id={`widget-${w.id}`}
          data-widget-panel={w.id}
          class:list={['visor__widget-section', i !== 0 && 'is-hidden']}
          hidden={i !== 0}
        >
          <header class="visor__widget-head">
            <div class="visor__widget-title">
              <h2>{w.name}</h2>
              <p>{w.description}</p>
            </div>
            <div class="visor__widget-toolbar">
              {/* Viewport switcher — Desktop/Tablet/Mobile */}
              <div class="visor__viewport-switcher" role="radiogroup" aria-label="Tamaño de viewport">
                <button
                  type="button"
                  class="visor__viewport-btn is-active"
                  data-viewport-target={w.id}
                  data-viewport="desktop"
                  aria-label="Desktop (ancho completo)"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <path d="M8 21h8M12 17v4"/>
                  </svg>
                  Desktop
                </button>
                <button
                  type="button"
                  class="visor__viewport-btn"
                  data-viewport-target={w.id}
                  data-viewport="tablet"
                  aria-label="Tablet (780px)"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="4" y="2" width="16" height="20" rx="2"/>
                    <path d="M11 18h2"/>
                  </svg>
                  Tablet
                </button>
                <button
                  type="button"
                  class="visor__viewport-btn"
                  data-viewport-target={w.id}
                  data-viewport="mobile"
                  aria-label="Mobile (375px)"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="6" y="2" width="12" height="20" rx="2"/>
                    <path d="M11 18h2"/>
                  </svg>
                  Mobile
                </button>
              </div>

              {/* Toggle del drawer de props */}
              <button
                type="button"
                class="visor__edit-toggle"
                data-edit-toggle={w.id}
                aria-pressed="false"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Props
              </button>
            </div>
          </header>

          <div class="visor__widget-body" data-widget-body={w.id}>
            {/* Preview — todas las variantes pre-renderizadas; JS muestra/oculta */}
            <div class="visor__preview-wrap">
              <div class="visor__preview-frame" data-preview-frame={w.id} data-viewport="desktop">
                <div data-preview-root={w.id}>
{w.variants.flatMap((v) =>
                    (['light', 'dark'] as const).map((mode) => {
                      // ID único por combinación variant × mode (sin espacios problemáticos).
                      const previewId = `preview-${w.id}-${v.id}-${mode}`;
                      
                      const adapterInput = {
                        title: w.defaults.title,
                        description: w.defaults.description,
                        variant: v.id,
                        id: previewId,
                        mode: mode,
                        ...(w.defaults.cards ? { cards: w.defaults.cards } : {}),
                      };

                      const componentProps = w.propsAdapter
                        ? w.propsAdapter(adapterInput)
                        : {
                            title: w.defaults.title,
                            description: w.defaults.description,
                            variant: v.id as 'v2.1' | 'v2.2',
                            id: previewId,
                            mode: mode,
                          };
                      
                      // Por defecto solo se muestra la combinación variant × mode por defecto.
                      // Las demás quedan en el DOM (con [hidden]) para que el cambio de
                      // variante o modo sea instantáneo sin re-render del servidor.
                      // El JS muestra/oculta cambiando este atributo según la selección.
                      const isDefaultVariant = v.id === w.defaultVariant;
                      const isDefaultMode = mode === (w.defaults.mode ?? 'light');
                      const isVisible = isDefaultVariant && isDefaultMode;

                      return (
                        <div
                          class="visor__preview-instance"
                          data-preview-instance={w.id}
                          data-preview-variant={v.id}
                          data-preview-mode={mode}
                          hidden={!isVisible}
                        >
                          <w.component {...componentProps} />
                        </div>
                      );
                    })
                  )}
                </div>
              </div>
            </div>

            {/* Drawer de props */}
            <aside class="visor__controls">
              <div class="visor__control">
                <label for={`variant-${w.id}`}>Variante</label>
                <select id={`variant-${w.id}`} data-control="variant" data-widget={w.id}>
                  {w.variants.map((v) => (
                    <option value={v.id} selected={v.id === w.defaultVariant}>
                      {v.label}
                    </option>
                  ))}
                </select>
              </div>

              <div class="visor__control">
                <label>Modo</label>
                <div class="visor__mode-switcher" role="radiogroup" aria-label="Modo del widget">
                  <button
                    type="button"
                    class:list={['visor__mode-btn', (w.defaults.mode ?? 'light') === 'light' && 'is-active']}
                    data-mode-set={w.id}
                    data-mode-value="light"
                    role="radio"
                    aria-checked={(w.defaults.mode ?? 'light') === 'light' ? 'true' : 'false'}
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="5"/>
                      <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                      <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                    Claro
                  </button>
                  <button
                    type="button"
                    class:list={['visor__mode-btn', (w.defaults.mode ?? 'light') === 'dark' && 'is-active']}
                    data-mode-set={w.id}
                    data-mode-value="dark"
                    role="radio"
                    aria-checked={(w.defaults.mode ?? 'light') === 'dark' ? 'true' : 'false'}
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                    Oscuro
                  </button>
                </div>
              </div>

              <div class="visor__control">
                <label for={`title-${w.id}`}>Título</label>
                <input
                  id={`title-${w.id}`}
                  type="text"
                  data-control="title"
                  data-widget={w.id}
                  value={w.defaults.title}
                />
              </div>

              <div class="visor__control">
                <label for={`desc-${w.id}`}>{w.defaults.cards ? 'Bajada (HTML permitido)' : 'Descripción (HTML permitido)'}</label>
                <textarea
                  id={`desc-${w.id}`}
                  data-control="description"
                  data-widget={w.id}
                  rows="5"
                  set:text={w.defaults.description}
                />
              </div>

              {/* Editor de cards (solo si el widget las expone en defaults) */}
              {w.defaults.cards && (
                <div class="visor__control">
                  <label>
                    Cards
                    <span class="visor__control-hint-inline">
                      (vacías no se renderizan — comportamiento ACF)
                    </span>
                  </label>
                  <div class="visor__cards-list" data-cards-editor={w.id}>
                    {w.defaults.cards.map((card, i) => (
                      <div class="visor__card-row" data-card-row={i}>
                        <select
                          class="visor__card-icon"
                          data-card-field={`iconSlug-${w.id}-${i}`}
                          aria-label="Icono"
                        >
                          <option value="fecha" selected={card.iconSlug === 'fecha'}>📅 Fecha</option>
                          <option value="hora" selected={card.iconSlug === 'hora'}>🕐 Hora</option>
                          <option value="presencial" selected={card.iconSlug === 'presencial'}>👥 Presencial</option>
                          <option value="virtual" selected={card.iconSlug === 'virtual'}>📶 Virtual</option>
                          <option value="hibrida" selected={card.iconSlug === 'hibrida'}>💻 Híbrida</option>
                        </select>
                        <input
                          type="text"
                          placeholder="Etiqueta (ej. Fecha:)"
                          value={card.label}
                          data-card-field={`label-${w.id}-${i}`}
                          aria-label="Etiqueta"
                        />
                        <input
                          type="text"
                          placeholder="Valor (ej. 25 y 26 abril)"
                          value={card.value}
                          data-card-field={`value-${w.id}-${i}`}
                          aria-label="Valor"
                        />
                        <button
                          type="button"
                          class="visor__card-remove"
                          data-card-remove={i}
                          aria-label="Eliminar card"
                        >✕</button>
                      </div>
                    ))}
                  </div>
                  <button
                    type="button"
                    class="visor__card-add"
                    data-card-add={w.id}
                  >
                    + Agregar card
                  </button>
                </div>
              )}

              <p class="visor__controls-hint">
                💡 Estos campos mapean 1:1 con los Custom Fields de WordPress (ACF).
                Al editar, el preview se actualiza en vivo.
              </p>
            </aside>
          </div>
        </section>
      ))}
    </main>
  </div>

  {/* ============================================================
      Lógica cliente — bundle inline (~4KB, sin deps)
      ============================================================ */}
  <script is:inline define:vars={{ ICON_PATHS }}>
    /* Script inline — Astro lo trata como is:inline por usar define:vars.
       Mantenido como JS plano (sin tipos TS) para que Astro no lo parsee. */

    const STORAGE_BU = 'visor:bu';
    const root = document.documentElement;

    // ── 1. Switcher de Unidad de Negocio ────────────────────────
function applyBu(bu) {
      root.setAttribute('data-bu', bu);
      document
        .querySelectorAll('[data-bu-target]')
        .forEach((btn) => {
          const isActive = btn.dataset.buTarget === bu;
          btn.setAttribute('aria-checked', String(isActive));
          btn.classList.toggle('is-active', isActive);
        });
    }

    const savedBu = localStorage.getItem(STORAGE_BU) ?? 'pregrado';
    applyBu(savedBu);

    document
      .querySelectorAll('[data-bu-target]')
      .forEach((btn) => {
        btn.addEventListener('click', () => {
          const bu = btn.dataset.buTarget;
          if (!bu) return;
          applyBu(bu);
          localStorage.setItem(STORAGE_BU, bu);
        });
      });

    // ── 2. Viewport switcher (Desktop / Tablet / Mobile) ────────
    document
      .querySelectorAll('[data-viewport-target]')
      .forEach((btn) => {
        btn.addEventListener('click', () => {
          const widgetId = btn.dataset.viewportTarget;
          const viewport = btn.dataset.viewport;
          if (!widgetId || !viewport) return;

          const frame = document.querySelector(`[data-preview-frame="${widgetId}"]`);
          if (frame) frame.setAttribute('data-viewport', viewport);

          // Marcar botón activo dentro del mismo switcher
          btn.parentElement
            ?.querySelectorAll('[data-viewport-target]')
            .forEach((b) => b.classList.toggle('is-active', b === btn));
        });
      });

    // ── 3. Edit Props toggle (abre/cierra el drawer) ────────────
    document
      .querySelectorAll('[data-edit-toggle]')
      .forEach((btn) => {
        btn.addEventListener('click', () => {
          const widgetId = btn.dataset.editToggle;
          if (!widgetId) return;
          const body = document.querySelector(`[data-widget-body="${widgetId}"]`);
          if (!body) return;
          const isOpen = body.classList.toggle('has-controls');
          btn.classList.toggle('is-active', isOpen);
          btn.setAttribute('aria-pressed', String(isOpen));
        });
      });

    // ── 4. Live prop editing ────────────────────────────────────

    // Iconos Font Awesome Free (paths completos) — inyectados desde
    // `widgets/5-save-the-date/icons.ts` vía <script define:vars>.
    // Si querés cambiar un icono, editá solo ese archivo.
    const ICONS_SVG = ICON_PATHS;

    function getCards(widgetId) {
      // Lee el estado actual del editor de cards desde el DOM.
      const rows = document.querySelectorAll(
        `[data-cards-editor="${widgetId}"] [data-card-row]`
      );
      return Array.from(rows).map((row) => {
        const icon = row.querySelector('.visor__card-icon')?.value ?? 'fecha';
        const label = row.querySelector('input[aria-label="Etiqueta"]')?.value ?? '';
        const value = row.querySelector('input[aria-label="Valor"]')?.value ?? '';
        return { iconSlug: icon, label, value };
      });
    }

    function renderCards(widgetId) {
      const cards = getCards(widgetId);
      const instances = document.querySelectorAll(`[data-preview-instance="${widgetId}"]`);
      instances.forEach((inst) => {
        const container = inst.querySelector('.hk-std-cards-container');
        if (!container) return;
        // Cards válidas (no vacías) — comportamiento ACF.
        const valid = cards.filter((c) => c.label.trim() && c.value.trim()).slice(0, 6);
        container.innerHTML = valid
          .map((c) => {
            const path = ICONS_SVG[c.iconSlug] ?? ICONS_SVG.fecha;
            const iconSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="hk-card-icon"><path d="${path}"/></svg>`;
            return `
              <div class="hk-std-card px-8 py-6 bg-bu-accent text-bu-surface rounded-lg flex items-center justify-center gap-4 lg:w-[300px] lg:min-w-[300px] md:w-[300px] md:min-w-[300px] w-[280px] min-w-[280px] flex-none" data-card-icon="${c.iconSlug}">
                <div class="flex justify-center items-center shrink-0">${iconSvg}</div>
                <div class="box-contenido w-[120px] md:w-fit text-left">
                  <h3 class="hk-card-label font-montserrat text-mont-card-content-mobile md:text-mont-card-content font-normal">${c.label}</h3>
                  <p class="hk-card-value font-montserrat text-mont-card-title-mobile md:text-mont-card-title font-extrabold">${c.value}</p>
                </div>
              </div>
            `;
          })
          .join('');
      });
    }

    document
      .querySelectorAll('[data-control]')
      .forEach((ctrl) => {
        const widgetId = ctrl.dataset.widget;
        const control = ctrl.dataset.control;
        if (!widgetId || !control) return;

        const apply = () => {
          const instances = document.querySelectorAll(
            `[data-preview-instance="${widgetId}"]`
          );
          if (!instances.length) return;

          if (control === 'variant') {
            const v = ctrl.value;
            // Detectar el modo actual (de la instancia visible).
            const currentMode =
              document
                .querySelector(`[data-preview-instance="${widgetId}"]:not([hidden])`)
                ?.dataset.previewMode ?? 'light';
            instances.forEach((inst) => {
              const match =
                inst.dataset.previewVariant === v &&
                inst.dataset.previewMode === currentMode;
              inst.hidden = !match;
            });
            return;
          }

          instances.forEach((inst) => {
            if (control === 'title') {
              const h = inst.querySelector('.hk-title');
              if (h) h.textContent = ctrl.value;
            } else if (control === 'description') {
              const d = inst.querySelector('.hk-desc');
              if (d) d.innerHTML = ctrl.value;
            }
          });
        };

        ctrl.addEventListener('input', apply);
        ctrl.addEventListener('change', apply);
      });

    // ── 4b. Cards editor (add / remove / live edit) ─────────────
    document.querySelectorAll('[data-cards-editor]').forEach((editor) => {
      const widgetId = editor.dataset.cardsEditor;
      if (!widgetId) return;

      // Live edit en cualquier campo de card → re-render
      editor.addEventListener('input', () => renderCards(widgetId));
      editor.addEventListener('change', () => renderCards(widgetId));

      // Eliminar card
      editor.addEventListener('click', (e) => {
        const target = e.target;
        const removeIdx = target.dataset.cardRemove;
        if (removeIdx === undefined) return;
        const row = editor.querySelector(`[data-card-row="${removeIdx}"]`);
        row?.remove();
        // Reindexar data-card-row para que sigan siendo únicos
        editor.querySelectorAll('[data-card-row]').forEach((r, i) => {
          r.setAttribute('data-card-row', String(i));
          r.querySelector('[data-card-remove]')?.setAttribute('data-card-remove', String(i));
        });
        renderCards(widgetId);
      });
    });

    // Botón "+ Agregar card"
    document.querySelectorAll('[data-card-add]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const widgetId = btn.dataset.cardAdd;
        if (!widgetId) return;
        const editor = document.querySelector(`[data-cards-editor="${widgetId}"]`);
        if (!editor) return;
        const nextIdx = editor.querySelectorAll('[data-card-row]').length;
        const row = document.createElement('div');
        row.className = 'visor__card-row';
        row.setAttribute('data-card-row', String(nextIdx));
        row.innerHTML = `
          <select class="visor__card-icon" aria-label="Icono">
            <option value="fecha" selected>📅 Fecha</option>
            <option value="hora">🕐 Hora</option>
            <option value="presencial">👥 Presencial</option>
            <option value="virtual">📶 Virtual</option>
            <option value="hibrida">💻 Híbrida</option>
          </select>
          <input type="text" placeholder="Etiqueta (ej. Fecha:)" aria-label="Etiqueta" />
          <input type="text" placeholder="Valor (ej. 25 y 26 abril)" aria-label="Valor" />
          <button type="button" class="visor__card-remove" data-card-remove="${nextIdx}" aria-label="Eliminar card">✕</button>
        `;
        editor.appendChild(row);
        // Re-index anteriores por seguridad
        editor.querySelectorAll('[data-card-row]').forEach((r, i) => {
          r.setAttribute('data-card-row', String(i));
        });
        renderCards(widgetId);
      });
    });

    // ── 4c. Mode switcher (light / dark por instancia) ─────────
    document
      .querySelectorAll('[data-mode-set]')
      .forEach((btn) => {
        btn.addEventListener('click', () => {
          const widgetId = btn.dataset.modeSet;
          const mode = btn.dataset.modeValue;
          if (!widgetId || !mode) return;

          // 1. Encontrar la variante actualmente visible para este widget
          //    (la única instancia sin `hidden`).
          const currentVariant = document
            .querySelector(`[data-preview-instance="${widgetId}"]:not([hidden])`)
            ?.dataset.previewVariant;

          // 2. Mostrar/ocultar las instancias correctas: misma variante,
          //    nuevo mode. Las demás (otras variantes) quedan ocultas.
          document
            .querySelectorAll(`[data-preview-instance="${widgetId}"]`)
            .forEach((inst) => {
              const matchesNew =
                inst.dataset.previewVariant === currentVariant &&
                inst.dataset.previewMode === mode;
              inst.hidden = !matchesNew;
            });

          // 3. Marcar botón activo en el switcher
          btn.parentElement
            ?.querySelectorAll('[data-mode-set]')
            .forEach((b) => {
              const isActive = b === btn;
              b.classList.toggle('is-active', isActive);
              b.setAttribute('aria-checked', String(isActive));
            });
        });
      });

    // ── 5. Navegación del sidebar (mostrar un widget a la vez) ──
    const STORAGE_WIDGET = 'visor:widget';

    function showWidget(widgetId) {
      // Ocultar todos los panels y mostrar solo el seleccionado
      document.querySelectorAll('[data-widget-panel]').forEach((panel) => {
        const isActive = panel.dataset.widgetPanel === widgetId;
        panel.hidden = !isActive;
        panel.classList.toggle('is-hidden', !isActive);
      });

      // Marcar el link activo en el sidebar
      document.querySelectorAll('[data-widget-nav]').forEach((link) => {
        const isActive = link.dataset.widgetNav === widgetId;
        link.classList.toggle('is-active', isActive);
        if (isActive) link.setAttribute('aria-current', 'true');
        else link.removeAttribute('aria-current');
      });

      // Cerrar el drawer de props al cambiar de widget
      document.querySelectorAll('[data-widget-body]').forEach((body) => {
        body.classList.remove('has-controls');
      });
      document.querySelectorAll('[data-edit-toggle]').forEach((btn) => {
        btn.classList.remove('is-active');
        btn.setAttribute('aria-pressed', 'false');
      });

      // Scroll al top del main
      document.querySelector<HTMLElement>('.visor__main')?.scrollTo({ top: 0, behavior: 'smooth' });
    }

    document.querySelectorAll('[data-widget-nav]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const widgetId = a.dataset.widgetNav;
        if (!widgetId) return;
        e.preventDefault();
        showWidget(widgetId);
        localStorage.setItem(STORAGE_WIDGET, widgetId);
        // Actualizar el hash sin scroll nativo
        history.replaceState(null, '', `#${widgetId}`);
      });
    });

    // Restaurar widget seleccionado (o abrir el primero)
    const initialWidget =
      location.hash.replace('#', '') ||
      localStorage.getItem(STORAGE_WIDGET) ||
      document.querySelector<HTMLElement>('[data-widget-panel]')?.dataset.widgetPanel;
    if (initialWidget) showWidget(initialWidget);
  </script>
</BaseLayout>