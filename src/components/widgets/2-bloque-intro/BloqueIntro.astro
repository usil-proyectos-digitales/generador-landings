---
/**
 * BloqueIntro — Widget "Bloque Intro Texto" (id: `2-bloque-intro`).
 * --------------------------------------------------------------
 * Migración a Astro del widget legacy en `src/widgets/2-bloque-intro/`.
 *
 * Sistema de color:
 *   El widget consume las 5 variables semánticas del Design System V2,
 *   definidas en `[data-bu="..."]` dentro de `src/styles/global.css`:
 *     - --bu-color-brand-primary   → CTAs fuertes, títulos destacados
 *     - --bu-color-brand-secondary → Soporte, texto alterno
 *     - --bu-color-accent-primary  → Highlights, badges
 *     - --bu-color-surface-light   → Fondo claro / texto sobre fondo oscuro
 *     - --bu-color-neutral         → Texto principal sobre fondos claros
 *
 *   Al cambiar `data-bu` del <html> en runtime (switcher del visor),
 *   estas 5 variables se reescriben y el widget se repinta sin recargar.
 *
 * Mapeo de tokens por variante:
 *   - v2.1 (centrado):  bg=primary,    text=surface
 *   - v2.2 (dividido):  bg=surface,    text=primary (título y descripción)
 *
 * Tipografía parametrizable vía props (`fontTitle`, `fontBody`) con
 * defaults equivalentes al legacy (`font-anton` / `font-montserrat`).
 *
 * Pensado para integración 1:1 con Custom Fields de WordPress (ACF):
 *   - `title`       ← ACF `text`     "Título Principal"
 *   - `description` ← ACF `wysiwyg`  "Descripción Principal" (HTML permitido)
 *   - `variant`     ← switch interno  ('v2.1' centrado | 'v2.2' dividido)
 *   - `id`          ← opcional, para anchors y analytics
 */
interface Props {
  /** Título principal (string plano, escapado automáticamente por Astro). */
  title: string;
  /** Descripción / bajada. HTML permitido porque viene de un WYSIWYG ACF. */
  description: string;
  /** Variante visual. Default: 'v2.1' (centrado). */
  variant?: 'v2.1' | 'v2.2';
  /** ID del <section>, útil para anchors y tracking. */
  id?: string;
  /** Familia tipográfica del título (default: 'anton' = legacy v2.1). */
  fontTitle?: 'anton' | 'montserrat';
  /** Familia tipográfica del cuerpo (default: 'montserrat'). */
  fontBody?: 'montserrat';
}

const {
  title,
  description,
  variant = 'v2.1',
  id = 'bloque-intro',
  fontTitle = variant === 'v2.1' ? 'anton' : 'montserrat',
  fontBody = 'montserrat',
} = Astro.props;

// Helpers: clases por familia tipográfica.
const titleFontClass = fontTitle === 'anton' ? 'font-anton' : 'font-montserrat';
const bodyFontClass = fontBody === 'montserrat' ? 'font-montserrat' : 'font-montserrat';

// Clases base compartidas — se reusan en ambas variantes.
const sectionBase =
  'relative py-16 w-full transition-opacity duration-300 md:py-24';
const containerCls = 'container relative z-10 px-4 mx-auto md:px-6';
---

{/* ─────────────────────────────────────────────────────────────── */}
{/* VARIANTE 2.1 — Centrado: fondo primary, texto surface           */}
{/* ─────────────────────────────────────────────────────────────── */}
{variant === 'v2.1' && (
  <section
    id={id}
    data-widget="bloque-intro"
    data-variant="v2.1"
    class:list={[sectionBase, 'bg-bu-primary text-bu-surface']}
  >
    <div class={containerCls}>
      <div class="flex flex-col justify-center items-center mx-auto space-y-8 text-center">
        <h2
          class:list={[
            'hk-title',
            titleFontClass,
            'text-anton-block-title-mobile md:text-anton-block-title',
          ]}
        >
          {title}
        </h2>

        {/* set:html permite contenido enriquecido del WYSIWYG (p, strong, em, ul, etc.) */}
        <p
          class:list={[
            'mx-auto max-w-4xl hk-desc',
            bodyFontClass,
            'text-mont-block-p-mobile md:text-mont-block-p',
          ]}
          set:html={description}
        />
      </div>
    </div>
  </section>
)}

{/* ─────────────────────────────────────────────────────────────── */}
{/* VARIANTE 2.2 — Dividido: fondo surface, texto primary           */}
{/* ─────────────────────────────────────────────────────────────── */}
{variant === 'v2.2' && (
  <section
    id={id}
    data-widget="bloque-intro"
    data-variant="v2.2"
    class:list={[sectionBase, 'bg-bu-surface text-bu-primary']}
  >
    <div class={containerCls}>
      <div class="grid gap-12 items-start lg:grid-cols-12">

        {/* Columna izquierda: Título */}
        <div class="space-y-4 lg:col-span-5">
          <h2
            class:list={[
              'text-center hk-title text-bu-primary',
              titleFontClass,
              'text-mont-block-title-mobile md:text-mont-block-title md:text-left',
            ]}
          >
            {title}
          </h2>
        </div>

        {/* Columna derecha: Texto */}
        <div class="space-y-6 lg:col-span-7">
          <p
            class:list={[
              'text-center hk-desc text-bu-secondary',
              bodyFontClass,
              'text-mont-block-p-mobile md:text-mont-block-p md:text-left',
            ]}
            set:html={description}
          />
        </div>
      </div>
    </div>
  </section>
)}