---
/**
 * SaveTheDate — Widget "Save the Date" (id: `5-save-the-date`).
 * --------------------------------------------------------------
 * Migración a Astro del widget legacy.
 *
 * Renderiza un bloque con:
 *   - Título principal (Save the Date)
 *   - 1–6 cards con icono SVG + etiqueta + valor
 *   - Texto de bajada (lugar / dirección)
 *
 * Sistema de color:
 *   Tokens centralizados en `./theme.ts` — editá solo ese archivo
 *   para ajustar colores. Las clases resuelven a CSS variables
 *   del Design System V2 → cambian con el BU en runtime.
 *   Los SVGs usan `currentColor` → heredan color del texto padre.
 *
 * Iconos:
 *   SVG INLINE en `./icons.ts` (no archivos servidos).
 *   WordPress nunca los toca → evita problemas de sanitización.
 *
 * ACF (WordPress):
 *   - `title`       ← ACF `text`     "Título"
 *   - `cards[]`     ← ACF `repeater` "Cards" (label, value, iconSlug)
 *   - `bottomText`  ← ACF `wysiwyg`  "Texto bajada"
 *
 * Comportamiento:
 *   - Cards con `label` o `value` vacíos NO se renderizan.
 *   - Máximo 6 cards (defensa legacy).
 */
import { ICONS, type IconSlug } from './icons.ts';
import { theme, baseClasses, backgrounds } from './theme.ts';

export interface CardItem {
  label: string;
  value: string;
  iconSlug: IconSlug;
}

interface Props {
  title?: string;
  cards?: CardItem[];
  bottomText?: string;
  id?: string;
  fontTitle?: 'anton' | 'montserrat';
  background?: 'gray' | 'white' | 'transparent';
}

const {
  title = 'Save the Date',
  cards = [
    { label: 'Fecha:', value: '25 y 26 abril', iconSlug: 'fecha' },
    { label: 'Hora:', value: '9:00 - 18:00', iconSlug: 'hora' },
    { label: 'Modalidad:', value: 'Híbrida', iconSlug: 'modalidad' },
  ],
  bottomText = 'USIL, campus 1 - Aula Magna<br> <span class="font-normal">(av. La Fontana 550, La Molina)</span>',
  id = 'save-the-date',
  fontTitle = 'anton',
  background = 'gray',
} = Astro.props;

// ── Resolución de tokens desde theme.ts ─────────────────────
const tokens = theme['v5.7'];
const sectionBg = backgrounds[background];

const titleFontClass = fontTitle === 'anton' ? 'font-anton' : 'font-montserrat';

// ── Filtrado de cards ──────────────────────────────────────
// Cards con label o value vacíos NO se renderizan (comportamiento
// esperado en WP ACF cuando el editor no completa una fila del repeater).
const validCards = (cards ?? []).filter(
  (c) => c.label?.trim() && c.value?.trim()
).slice(0, 6);

// Caso especial legacy: 4 cards → ancho 700px (2x2 grid).
const cardsContainerClass =
  validCards.length === 4
    ? 'hk-std-cards-container flex flex-wrap justify-center gap-8 w-full max-w-[700px] mx-auto'
    : 'hk-std-cards-container flex flex-wrap justify-center gap-8 w-full max-w-[1280px] mx-auto';
---

<section
  id={id}
  data-widget="save-the-date"
  data-variant="v5.7"
  class:list={[baseClasses.section, sectionBg]}
>
  <div class={baseClasses.container}>
    <div class="relative z-10 text-center">
      {/* Título */}
      <h2
        class:list={[
          baseClasses.title,
          titleFontClass,
          tokens.title,
        ]}
      >
        {title}
      </h2>

      {/* Cards */}
      {validCards.length > 0 && (
        <div class={cardsContainerClass}>
          {validCards.map((card) => {
            const iconFn = ICONS[card.iconSlug] ?? ICONS.fecha;
            const iconSvg = iconFn({ class: 'hk-card-icon', size: 48 });
            return (
              <div
                class:list={[baseClasses.cardShell, tokens.card]}
                data-card-icon={card.iconSlug}
              >
                <div class="flex justify-center items-center shrink-0" set:html={iconSvg} />
                <div class="box-contenido w-[120px] md:w-fit text-left">
                  <h3 class:list={[baseClasses.cardLabel]}>
                    {card.label}
                  </h3>
                  <p class:list={[baseClasses.cardValue]}>
                    {card.value}
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      )}

      {/* Texto bajada (WYSIWYG) */}
      {bottomText && (
        <div class="mt-12">
          <p
            class:list={[baseClasses.bajada, tokens.bajada]}
            set:html={bottomText}
          />
        </div>
      )}
    </div>
  </div>
</section>