---
/**
 * Hero — Bloque hero de la landing.
 * Compatible con tokens `bu-*` (cambia según BU del <body data-bu="...">).
 * @prop eyebrow: texto pequeño arriba del título (ej. "ADMISIONES 2026-1")
 * @prop title: título principal
 * @prop subtitle: subtítulo / bajada
 * @prop ctaText: texto del CTA principal
 * @prop ctaUrl: URL del CTA
 * @prop ctaSecondaryText: texto del CTA secundario (opcional)
 * @prop ctaSecondaryUrl: URL del CTA secundario (opcional)
 * @prop variant: 'light' | 'dark' (default 'light')
 * @prop imageUrl: imagen de fondo (opcional)
 * @prop imageAlt: alt text de la imagen (opcional)
 */
import Button from './Button.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  ctaText: string;
  ctaUrl: string;
  ctaSecondaryText?: string;
  ctaSecondaryUrl?: string;
  variant?: 'light' | 'dark';
  imageUrl?: string;
  imageAlt?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  ctaText,
  ctaUrl,
  ctaSecondaryText,
  ctaSecondaryUrl,
  variant = 'light',
  imageUrl,
  imageAlt = '',
} = Astro.props;

const isDark = variant === 'dark';
---

<section
  class:list={[
    'relative w-full overflow-hidden',
    isDark ? 'bg-[var(--bu-color-surface-light)] text-[var(--bu-color-neutral)]' : 'bg-bu-surface text-bu-text',
    imageUrl ? 'min-h-[500px]' : 'py-20 md:py-28',
  ]}
>
  {imageUrl && (
    <>
      <img
        src={imageUrl}
        alt={imageAlt}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </>
  )}

  <div class="container relative z-10">
    <div class="max-w-3xl">
      {eyebrow && (
        <p class="text-bu-accent font-montserrat font-bold uppercase tracking-wider text-sm mb-4">
          {eyebrow}
        </p>
      )}

      <h1 class="font-montserrat font-extrabold text-4xl md:text-6xl leading-tight mb-6 text-balance">
        {title}
      </h1>

      {subtitle && (
        <p class="text-lg md:text-xl opacity-90 mb-8 max-w-2xl text-pretty">
          {subtitle}
        </p>
      )}

      <div class="flex flex-col sm:flex-row gap-4">
        <Button href={ctaUrl} variant="primary" size="lg">
          {ctaText}
        </Button>
        {ctaSecondaryText && ctaSecondaryUrl && (
          <Button href={ctaSecondaryUrl} variant="outline" size="lg">
            {ctaSecondaryText}
          </Button>
        )}
      </div>
    </div>
  </div>
</section>