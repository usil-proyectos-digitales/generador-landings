# WordPress Headless - REST API endpoint
# En dev apunta al staging de SiteGround; en prod a WP producción
WP_API_URL=https://landings-staging.usil.edu.pe/wp-json/wp/v2

# BU default cuando no se especifica en la página
WP_BU_DEFAULT=pregrado

# Google Gemini API (para fase de desarrollo)
# Obtener en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Modelo de Gemini a usar
GEMINI_MODEL=gemini-1.5-flash